[MAIN]
# pygame is a C extension; pylint can't introspect members like
# pygame.init, pygame.FULLSCREEN, pygame.SRCALPHA, etc. without this.
extension-pkg-allow-list=pygame,pygame._sdl2.audio

[FORMAT]
# 100 is tight for pygame draw calls with several positional/keyword args;
# 120 covers the codebase without meaningfully hurting readability.
max-line-length=120

[DESIGN]
# Thresholds bumped to fit this codebase's existing, working code (mostly
# pygame UI classes with several fonts/rects and drawing methods with many
# layout parameters) rather than forcing speculative refactors to satisfy
# pylint's generic defaults.
max-attributes=20
max-locals=40
max-args=20
max-positional-arguments=20
max-returns=15
max-branches=25
max-statements=75
max-module-lines=1300

[MESSAGES CONTROL]
disable=
    # Most UI/view classes here are intentionally single-purpose (one draw()
    # method plus tap-target attributes) rather than under-designed.
    too-few-public-methods,
    # ui.py's font objects are loaded lazily on first draw() (pygame.font
    # isn't ready before pygame.init()), not assigned in __init__ - a
    # deliberate, consistent pattern across every UI class, not an oversight.
    attribute-defined-outside-init,
    # A few modules (e.g. homegirl/speech.py) import optional/heavy
    # dependencies lazily on purpose, so importing the module doesn't require
    # every optional dependency to be installed.
    import-outside-toplevel,
    # Background service/fetch code (calendar, weather, speech) intentionally
    # catches broad exceptions so any failure just means "unavailable" rather
    # than crashing the always-on display.
    broad-exception-caught,
